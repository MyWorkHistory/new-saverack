APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL — must match the database user you created in cPanel (not necessarily "root").
# DB_PASSWORD empty causes: Access denied ... (using password: NO)
# DB_DATABASE must match phpMyAdmin exactly (e.g. saverack_saverack_new).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saverack_app
DB_USERNAME=root
DB_PASSWORD=

# Optional: old CRM MySQL (import database/customers*.sql first). Used by:
# php artisan crm:import-legacy-clients
# php artisan crm:sync-legacy-stripe-whatsapp
# LEGACY_DB_DATABASE=saverack_net
# LEGACY_DB_HOST=127.0.0.1
# LEGACY_DB_USERNAME=root
# LEGACY_DB_PASSWORD=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
ADMIN_NAME="Audi Kowalski"

# Deploy safety (production):
# - Never run migrate:fresh / migrate:refresh on live data. Use: php artisan migrate --force
# - Destructive artisan commands are blocked when APP_ENV=production unless ALLOW_DESTRUCTIVE_ARTISAN=true
ALLOW_DESTRUCTIVE_ARTISAN=false
# - RolePermissionSeeder syncs roles/permissions only by default in production (no user rows touched).
#   First deploy on an empty DB: set SEED_ENV_ADMIN_USER=true once, run db:seed, then remove or set false.
SEED_ENV_ADMIN_USER=
# - Demo staff1@…staff3@ (local only). Default off in production when this is unset.
SEED_DEMO_STAFF_USERS=

# CRM tickets module: only this email may access tickets (defaults to ADMIN_EMAIL if unset).
CRM_OWNER_EMAIL=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_DRIVER=database
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Outbound mail: Amazon SES SMTP.
# SES sandbox requires both sender and recipient identities to be verified.
# MAIL_HOST should use your SES SMTP region, e.g. email-smtp.us-east-1.amazonaws.com.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=email-smtp.<region>.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME="<SES SMTP user name>"
MAIL_PASSWORD="<SES SMTP password>"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="billing@saverack.com"
MAIL_FROM_NAME="Save Rack Billing"

# WhatsApp / Periskope invoice messaging.
# Client account WhatsApp API ID is sent as chat_id.
WHATSAPP_TOKEN=
WHATSAPP_NUMBER=
WHATSAPP_GROUP_ID=
# Optional override; defaults to Periskope's message send endpoint.
# WHATSAPP_ENDPOINT=https://api.periskope.app/v1/message/send

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ShipHero Public API (GraphQL) — https://developer.shiphero.com/getting-started/
# The current public API uses a refresh token only (no separate "API key"): POST to .../auth/refresh
# with JSON {"refresh_token":"..."} to obtain a Bearer JWT for https://public-api.shiphero.com/graphql
SHIPHERO_API_URL=https://public-api.shiphero.com/graphql
SHIPHERO_AUTH_URL=https://public-api.shiphero.com/auth
SHIPHERO_REFRESH_TOKEN=
# Optional server-wide fallback: ShipHero GraphQL `customer_account_id` when the Inventory UI does not
# select a CRM client account. Prefer storing per-client `shiphero_customer_account_id` on client_accounts
# and choosing the account on the Inventory page (3PL).
SHIPHERO_CUSTOMER_ACCOUNT_ID=

# CRM SPA (npm run build:crm): only if the app is served under a URL subpath, e.g. /crm/
# VITE_APP_BASE=/crm/
