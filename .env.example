APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL — must match the database user you created in cPanel (not necessarily "root").
# DB_PASSWORD empty causes: Access denied ... (using password: NO)
# DB_DATABASE must match phpMyAdmin exactly (e.g. saverack_saverack_new).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saverack_app
DB_USERNAME=root
DB_PASSWORD=

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
ADMIN_NAME="Audi Kowalski"

# Deploy safety (production):
# - Never run migrate:fresh / migrate:refresh on live data. Use: php artisan migrate --force
# - Destructive artisan commands are blocked when APP_ENV=production unless ALLOW_DESTRUCTIVE_ARTISAN=true
ALLOW_DESTRUCTIVE_ARTISAN=false
# - RolePermissionSeeder syncs roles/permissions only by default in production (no user rows touched).
#   First deploy on an empty DB: set SEED_ENV_ADMIN_USER=true once, run db:seed, then remove or set false.
SEED_ENV_ADMIN_USER=
# - Demo staff1@…staff3@ (local only). Default off in production when this is unset.
SEED_DEMO_STAFF_USERS=

# CRM tickets module: only this email may access tickets (defaults to ADMIN_EMAIL if unset).
CRM_OWNER_EMAIL=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_DRIVER=database
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Outbound mail: use smtp in production with your provider (Postmark, SES, Mailgun SMTP, etc.).
# Laravel reads these when MAIL_MAILER=smtp (see config/mail.php).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ShipHero Public API (GraphQL). Create a refresh token: https://developer.shiphero.com/getting-started/
SHIPHERO_API_URL=https://public-api.shiphero.com/graphql
SHIPHERO_AUTH_URL=https://public-api.shiphero.com/auth
SHIPHERO_REFRESH_TOKEN=
# Optional: 3PL customer account id (GraphQL customer_account_id) for product/inventory calls
SHIPHERO_CUSTOMER_ACCOUNT_ID=

# CRM SPA (npm run build:crm): only if the app is served under a URL subpath, e.g. /crm/
# VITE_APP_BASE=/crm/
